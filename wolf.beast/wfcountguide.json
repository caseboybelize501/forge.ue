    "title": "LayerEngine Count Reconciliation Protocol",
    "description": "Completeness as arithmetic, not assumption. One count flows through every layer. Delta can only be zero or positive. Never negative. A layer cannot close until its count matches or exceeds the previous layer's locked count.",
    "version": "1.0.0",
    
    "GOVERNANCE": {
        "parent_document": "layer1sys_arch.json (Layer 1 Phase 9)",
        "status": "READ-ONLY — Layer 1 frozen. Modifications require return to source phase.",
        "layer": "L1",
        "phase": "Count Protocol"
    },

    "principles": {
        "core_rule": "count(files_produced) must equal count(files_planned) at every layer close",
        "delta_rule": "Each layer's file count must be >= the previous layer's locked count. Delta can grow. It cannot shrink.",
        "gate_rule": "A layer cannot advance until its count gate passes. No exceptions.",
        "trust_rule": "Critics validate correctness. Count reconciliation validates completeness. Both are required. Neither replaces the other."
    },
    "count_chain": {
        "description": "The full count lineage from Layer 1 through Layer 3. One number originates at L1 Phase 9 and is inherited as a hard floor at every subsequent gate.",
        "links": [
            {
                "id": "L1_LOCK",
                "layer": 1,
                "phase": 9,
                "document": "critic_final.md",
                "gate_name": "L1_MANIFEST_COUNT",
                "description": "Count every file in file_manifest.md. Count every stub in structure_confirmed.md. These two numbers must match exactly before critic_final.md can be written.",
                "inputs": {
                    "manifest_source": "file_manifest.md",
                    "structure_source": "structure_confirmed.md"
                },
                "fields_written": {
                    "L1_MANIFEST_COUNT": "integer â€” total files in file_manifest.md",
                    "L1_STRUCTURE_COUNT": "integer â€” total stub files in structure_confirmed.md",
                    "STATUS": "MATCH âœ“ | MISMATCH âœ—"
                },
                "pass_condition": "L1_MANIFEST_COUNT === L1_STRUCTURE_COUNT",
                "fail_action": "STOP. Return to Phase 5 (file_manifest.md) and reconcile before proceeding.",
                "on_pass": "critic_final.md is APPROVED. L1_MANIFEST_COUNT is now a hard contract inherited by Layer 2."
            },
            {
                "id": "L2_MANIFEST_GATE",
                "layer": 2,
                "phase": 5,
                "document": "file_manifest2.md",
                "gate_name": "L2_MANIFEST_COUNT",
                "description": "Read L1_MANIFEST_COUNT from critic_final.md. Count every file in file_manifest2.md. L2 count must be >= L1 count.",
                "inputs": {
                    "contract_source": "critic_final.md â†’ L1_MANIFEST_COUNT",
                    "manifest_source": "file_manifest2.md"
                },
                "fields_written": {
                    "L1_CONTRACT_COUNT": "integer â€” inherited from critic_final.md",
                    "L2_MANIFEST_COUNT": "integer â€” total files in file_manifest2.md",
                    "DELTA": "integer â€” L2_MANIFEST_COUNT minus L1_CONTRACT_COUNT",
                    "STATUS": "COMPLETE âœ“ | INCOMPLETE âœ— ([N] files missing)"
                },
                "pass_condition": "L2_MANIFEST_COUNT >= L1_CONTRACT_COUNT",
                "fail_action": "STOP. Return to Phase 3 (dependency_graph2.md) and find what was dropped.",
                "on_pass": "file_manifest2.md is locked. L2_MANIFEST_COUNT is the new floor for the coding schedule.",
                "notes": "Positive delta is valid and expected â€” Layer 2 often discovers files Layer 1 did not anticipate. New files must be marked NEW in the manifest. Negative delta is never valid."
            },
            {
                "id": "L2_SCHEDULE_GATE",
                "layer": 2,
                "phase": 10,
                "document": "codingschedule.md",
                "gate_name": "SCHEDULE_FILE_COUNT",
                "description": "Read L2_MANIFEST_COUNT from file_manifest2.md. Count every file assigned a task ID in codingschedule.md. These two numbers must match exactly.",
                "inputs": {
                    "contract_source": "file_manifest2.md â†’ L2_MANIFEST_COUNT",
                    "schedule_source": "codingschedule.md"
                },
                "fields_written": {
                    "L2_MANIFEST_COUNT": "integer â€” inherited from file_manifest2.md",
                    "SCHEDULE_FILE_COUNT": "integer â€” total files with an assigned task ID",
                    "STATUS": "COMPLETE âœ“ | INCOMPLETE âœ— ([N] files unscheduled)"
                },
                "pass_condition": "SCHEDULE_FILE_COUNT === L2_MANIFEST_COUNT",
                "fail_action": "STOP. Find every file in the manifest with no task ID. Assign them. Do not close the schedule until counts match.",
                "on_pass": "codingschedule.md is locked. SCHEDULE_FILE_COUNT becomes the denominator for all Layer 3 running totals."
            },
            {
                "id": "L3_SESSION_GATE",
                "layer": 3,
                "phase": "each_session_critic",
                "document": "codecriticlayer3phaseN.md",
                "gate_name": "RUNNING_TOTAL",
                "description": "At the end of every Layer 3 session critic, update the running completion total. Files completed is cumulative across all sessions.",
                "inputs": {
                    "denominator_source": "codingschedule.md â†’ SCHEDULE_FILE_COUNT",
                    "numerator_source": "cumulative completed files across all sessions"
                },
                "fields_written": {
                    "FILES_SCHEDULED": "integer â€” from codingschedule.md header (constant)",
                    "FILES_COMPLETED": "integer â€” cumulative across all sessions to date",
                    "FILES_REMAINING": "integer â€” FILES_SCHEDULED minus FILES_COMPLETED",
                    "SESSIONS_COMPLETED": "integer",
                    "COMPLETION_PCT": "number â€” FILES_COMPLETED / FILES_SCHEDULED * 100",
                    "STATUS": "ON_TRACK | BEHIND | COMPLETE"
                },
                "pass_condition": "FILES_COMPLETED <= FILES_SCHEDULED",
                "complete_condition": "FILES_COMPLETED === FILES_SCHEDULED",
                "fail_action": "If FILES_COMPLETED > FILES_SCHEDULED: count error â€” recount and reconcile with codingschedule.md."
            }
        ]
    },
    "gate_header_templates": {
        "description": "Exact header blocks to be written into each gated document. These are machine-readable and parsed by the verifier.",
        "critic_final_md": {
            "format": "L1_MANIFEST_COUNT: {n}\nL1_STRUCTURE_COUNT: {n}\nSTATUS: MATCH âœ“\nAPPROVED.",
            "required_fields": [
                "L1_MANIFEST_COUNT",
                "L1_STRUCTURE_COUNT",
                "STATUS"
