        "file_manifest2_md": {
            "format": "L1_CONTRACT_COUNT: {n}\nL2_MANIFEST_COUNT: {x}\nDELTA: {x-n}\nSTATUS: COMPLETE âœ“",
            "required_fields": [
                "L1_CONTRACT_COUNT",
                "L2_MANIFEST_COUNT",
                "DELTA",
                "STATUS"
            ],
            "delta_annotation": "Any file with positive delta origin must be marked NEW inline in the manifest body."
        },
        "codingschedule_md": {
            "format": "L2_MANIFEST_COUNT: {x}\nSCHEDULE_FILE_COUNT: {y}\nSTATUS: COMPLETE âœ“",
            "required_fields": [
                "L2_MANIFEST_COUNT",
                "SCHEDULE_FILE_COUNT",
                "STATUS"
            ]
        },
        "codecriticlayer3_md": {
            "format": "FILES_SCHEDULED: {x}\nFILES_COMPLETED: {y}\nFILES_REMAINING: {x-y}\nSESSIONS_COMPLETED: {n}\nCOMPLETION_PCT: {pct}%\nSTATUS: ON_TRACK | BEHIND | COMPLETE",
            "required_fields": [
                "FILES_SCHEDULED",
                "FILES_COMPLETED",
                "FILES_REMAINING",
                "SESSIONS_COMPLETED",
                "COMPLETION_PCT",
                "STATUS"
            ]
        }
    },
    "verifier": {
        "description": "Programmatic checks run at each gate. All must pass before the layer advances.",
        "checks": [
            {
                "id": "CRP-V01",
                "gate": "L1_LOCK",
                "check": "L1_MANIFEST_COUNT === L1_STRUCTURE_COUNT",
                "error": "File manifest and folder structure counts do not match. Return to Phase 5.",
                "blocking": true
            },
            {
                "id": "CRP-V02",
                "gate": "L2_MANIFEST_GATE",
                "check": "L2_MANIFEST_COUNT >= L1_CONTRACT_COUNT",
                "error": "Layer 2 manifest has fewer files than Layer 1 locked count. Files were dropped. Return to Phase 3.",
                "blocking": true
            },
            {
                "id": "CRP-V03",
                "gate": "L2_MANIFEST_GATE",
                "check": "DELTA >= 0",
                "error": "Negative delta is never valid. Files cannot be removed between layers.",
                "blocking": true
            },
            {
                "id": "CRP-V04",
                "gate": "L2_SCHEDULE_GATE",
                "check": "SCHEDULE_FILE_COUNT === L2_MANIFEST_COUNT",
                "error": "Coding schedule does not cover all manifest files. Find unscheduled files and assign task IDs.",
                "blocking": true
            },
            {
                "id": "CRP-V05",
                "gate": "L3_SESSION_GATE",
                "check": "FILES_COMPLETED <= FILES_SCHEDULED",
                "error": "Completed count exceeds scheduled count. Count error â€” recount and reconcile.",
                "blocking": true
            },
            {
                "id": "CRP-V06",
                "gate": "ALL",
                "check": "All required_fields present in gate header",
                "error": "Gate header is missing required fields. Document is not valid for this gate.",
                "blocking": true
            }
        ]
    },
    "integration": {
        "description": "How count reconciliation integrates with the architectural JSON graph",
        "arch_graph_field": "commits[].verifier_result.checks",
        "new_check_added": "count_reconciliation_passed",
        "count_chain_stored_at": "meta.count_chain",
        "schema": {
