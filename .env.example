# FORGE Environment Configuration
# Copy this file to .env and fill in your values

# Unreal Engine 5 Installation
UNREAL_ENGINE_ROOT=C:\Program Files\Epic Games\UE_5.3

# Platform SDK Paths (optional - gates console packaging)
ANDROID_SDK_ROOT=
IOS_TOOLCHAIN=
SWITCH_SDK_ROOT=
PS5_SDK_ROOT=
XBOX_GDK_ROOT=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forge

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# LLM Inference (for architect_agent and repair_loop)
LLM_API_URL=http://localhost:8080
LLM_MODEL=llama-3-70b-q4_k_m

# API Security
JWT_SECRET_KEY=your-secret-key-change-in-production
API_KEY=your-api-key-change-in-production

# Platform SDK Gate (set to true to enable console packaging)
PLATFORM_SDK_AVAILABLE=false
